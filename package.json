{
  "name": "conversational-looker-dashboard",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter api --filter web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r build",
    "clean:artifacts": "node tools/clean-artifacts.mjs",
    "consolidate:results:csv": "node tools/consolidate-results-csv.mjs",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test-real-llm:evaluation": "bash -lc 'set -a; source .env; set +a; pnpm -C libs/application test-real-llm:evaluation'",
    "test-real-llm:evaluation:quick": "bash -lc 'set -a; source .env; set +a; pnpm -C libs/application test-real-llm:evaluation:quick'"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
