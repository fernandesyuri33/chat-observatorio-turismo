{
  "name": "application",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/application/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b libs/application/tsconfig.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests --config libs/application/vitest.config.ts"
      }
    },
    "test-real-llm": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests --config libs/application/vitest.config.ts libs/application/tests/application.real-llm.spec.ts",
        "env": {
          "RUN_REAL_LLM_TESTS": "true"
        }
      }
    }
  }
}
